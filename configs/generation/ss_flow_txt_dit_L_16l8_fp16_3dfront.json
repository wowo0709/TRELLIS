{
    "models": {
        "denoiser": {
            "name": "SparseStructureFlowModel",
            "args": {
                "resolution": 16,
                "in_channels": 4,
                "out_channels": 4,
                "model_channels": 768,
                "cond_channels": 768,
                "num_blocks": 12,
                "num_heads": 12,
                "mlp_ratio": 4,
                "patch_size": 1,
                "pe_mode": "ape",
                "qk_rms_norm": true,
                "use_fp16": true, 
                "use_context": true
            }
        }
    },
    "dataset": {
        "name": "CustomTextConditionedSparseStructureLatent",
        "type": "3dfront",
        "category": "bedrooms",
        "data_path": "/root/data/shape-generation/3D-FRONT/trellis_tmlr/bedrooms_without_lamps_full_ss_latent/images_256_zuniform-h3-r5_noair",
        "args": {
            "latent_model": "ss_vae_300k_b4x2_3dfront_bedroom_20260306_041812_step0150000",
            "min_aesthetic_score": 4.5,
            "ss_dec_path": "/root/data/shape-generation/TRELLIS/outputs/trellis_ss_vae/ss_vae_300k_b4x2_3dfront_bedroom_20260306_041812",
            "ss_dec_ckpt": "step0150000",
            "pretrained_ss_dec": "microsoft/TRELLIS-image-large/ckpts/ss_dec_conv3d_16l8_fp16",
            "aabb": [-3.0, -3.0, -3.0, 6.0, 6.0, 6.0]
        }
    },
    "trainer": {
        "name": "TextConditionedFlowMatchingCFGTrainer",
        "args": {
            "max_steps": 500000,
            "batch_size_per_gpu": 4,
            "batch_split": 4,
            "num_workers": 4,
            "optimizer": {
                "name": "AdamW",
                "args": {
                    "lr": 0.0001,
                    "weight_decay": 0.0
                }
            },
            "ema_rate": [
                0.9999
            ],
            "fp16_mode": "inflat_all",
            "fp16_scale_growth": 0.001,
            "grad_clip": {
                "name": "AdaptiveGradClipper",
                "args": {
                    "max_norm": 1.0,
                    "clip_percentile": 95
                }
            },
            "i_print": 10,
            "i_log": 10,
            "i_sample": 10000,
            "i_save": 50000,
            "enable_snapshot": false,
            "log_voxel_to_wandb": true,
            "voxel_log_num_images": 1,
            "p_uncond": 1.1,
            "t_schedule": {
                "name": "logitNormal",
                "args": {
                    "mean": 1.0,
                    "std": 1.0
                }
            },
            "sigma_min": 1e-5,
            "text_cond_model": "openai/clip-vit-large-patch14",
            "wandb_config": {
                "use_wandb": true,
                "project": "trellis_ss_flow", 
                "name": "ss_flow_txt_B_500k_b4x8_3dfront_bedrooms",
                "mode": "online"
            }
        }
    }
}
